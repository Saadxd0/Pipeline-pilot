# my.cnf — Custom MySQL configuration for PipelinePilot
# Placed in /etc/mysql/conf.d/ inside the container

[mysqld]
# Use UTF-8 everywhere so international project/pipeline names work correctly
character-set-server  = utf8mb4
collation-server      = utf8mb4_unicode_ci

# Allow up to 200 simultaneous connections (default is 151)
max_connections       = 200

# Keep idle connections alive for 10 minutes before dropping them
wait_timeout          = 600
interactive_timeout   = 600

# Increase the packet size limit for large SQL payloads
max_allowed_packet    = 64M

# Disable strict mode so SQLAlchemy's CREATE TABLE IF NOT EXISTS works cleanly
sql_mode              = STRICT_TRANS_TABLES,NO_ZERO_IN_DATE,NO_ZERO_DATE,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

[client]
default-character-set = utf8mb4

[mysql]
default-character-set = utf8mb4
