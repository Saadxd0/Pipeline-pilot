# .env.example — Copy to .env and fill in real values (never commit .env to git)

# ── Backend ──────────────────────────────────────────────────────────────────
DATABASE_URL=mysql+pymysql://pilot:pilotpass@localhost:3306/pipelinepilot
ALLOWED_ORIGINS=http://localhost:3000

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000

# ── MySQL (used by docker-compose) ───────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=pipelinepilot
MYSQL_USER=pilot
MYSQL_PASSWORD=pilotpass
